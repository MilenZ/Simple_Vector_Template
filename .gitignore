## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
build/
bin/
obj/

# Visual Studio cache/options
.vs/

# C++ specific
*.VC.db
*.VC.opendb
ipch/

# Logs
*.log

# Test results
TestResults/

# NuGet
packages/
*.nupkg

# Resharper
_ReSharper*/
*.DotSettings.user

# Windows
Thumbs.db
Desktop.ini

# Backup files
*.bak
*.tmp
*.old

# Executables
*.exe
*.dll
*.pdb
*.ilk